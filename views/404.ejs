
  <%- include('partials/head',{Page_title})%>
</head>

<body class="min-h-screen flex items-center justify-center bg-linear-to-br from-rose-100 via-pink-100 to-purple-100 relative overflow-hidden">

  <!-- Decorative Blobs -->
  <div class="absolute -top-24 -left-24 w-96 h-96 bg-rose-300 rounded-full blur-3xl opacity-30"></div>
  <div class="absolute -bottom-24 -right-24 w-96 h-96 bg-purple-300 rounded-full blur-3xl opacity-30"></div>

  <!-- Card -->
  <main class="relative bg-white/70 backdrop-blur-xl shadow-2xl rounded-3xl px-8 py-12 sm:px-14 sm:py-16 text-center max-w-lg w-full">

    <!-- Emoji / Illustration -->
    <div class="text-6xl mb-4">
      🧭
    </div>

    <!-- 404 -->
    <h1 class="text-7xl sm:text-8xl font-extrabold text-rose-500 tracking-tight">
      404
    </h1>

    <!-- Title -->
    <h2 class="mt-4 text-2xl sm:text-3xl font-semibold text-gray-800">
      Page Not Found
    </h2>

    <!-- Description -->
    <p class="mt-4 text-gray-600 leading-relaxed">
      Oops! The page you’re looking for doesn’t exist, was removed,
      or is temporarily unavailable.
    </p>

    <!-- Buttons -->
    <div class="mt-10 flex flex-col sm:flex-row gap-4 justify-center">
      <a
        href="/"
        class="bg-rose-500 text-white px-8 py-3 rounded-full font-semibold hover:bg-rose-600 transition shadow-lg hover:shadow-xl"
      >
        Go Home
      </a>
    </div>

  </main>

</body>
</html>
