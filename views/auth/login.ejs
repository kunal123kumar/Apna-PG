<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login</title>

    <!-- Tailwind compiled CSS -->
    <link rel="stylesheet" href="/output.css" />
  </head>

  <body class="min-h-screen relative flex items-center justify-center">
    <!-- Background Image -->
    <div
      class="absolute inset-0 bg-cover bg-center"
      style="
        background-image: url(&quot;https://img.freepik.com/premium-photo/beautiful-illustration-with-smoke-colorful-background_265989-17893.jpg?semt=ais_hybrid&w=740&q=80&quot;);
      "
    ></div>

    <!-- Dark Overlay -->
    <div class="absolute inset-0 bg-black/40"></div>

    <!-- Animated Gradient Overlay -->
    <div
      class="absolute inset-0 animate-gradient bg-gradient-to-br from-red-600/20 via-transparent to-red-700/20"
    ></div>

    <!-- Login Card -->
    <div
      class="relative z-10 w-full max-w-sm bg-white border border-gray-200 rounded-lg p-8 shadow-lg"
    >
      <h1 class="text-2xl font-semibold text-gray-900 mb-1">Log in</h1>
      <p class="text-sm text-gray-500 mb-6">
        Welcome back, please enter your details
      </p>

      <form action="/login" method="POST" class="space-y-4">
        <div>
          <% if ( errorMessage !== 'undefined') { %>
            <p class="text-sm text-red-600 mb-2"><%= errorMessage %></p>
          <% } %>
          <label class="block text-sm font-medium text-gray-700 mb-1">
            Email
          </label>
          <input
            type="email"
            name="email"
            required
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-1 focus:ring-red-600"
          />
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">
            Password
          </label>
          <input
            type="password"
            name="password"
            required
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-1 focus:ring-red-600"
          />
        </div>

        <button
          type="submit"
          class="w-full bg-red-600 text-white py-2 rounded-md font-medium hover:bg-red-700 transition"
        >
          Log in
        </button>

        <p class="text-sm text-gray-500">
          Don't have an account?
          <a href="/signup" class="text-red-600 hover:underline"
            >Sign up</a
          >
        </p>


      </form>
      
    </div>
  </body>
</html>
