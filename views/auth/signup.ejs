<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Sign up</title>
    <!-- Tailwind compiled CSS -->
    <link rel="stylesheet" href="/output.css" />
</head>

<body class="min-h-screen relative">
    <!-- Background Image -->
    <div class="absolute inset-0 bg-cover bg-center" style="
        background-image: url(&quot;https://img.freepik.com/premium-photo/beautiful-illustration-with-smoke-colorful-background_265989-17893.jpg?semt=ais_hybrid&w=740&q=80&quot;);
      "></div>

    <!-- Overlay -->
    <div class="absolute inset-0 bg-black/40"></div>
    <div class="absolute inset-0 bg-gradient-to-br from-red-600/20 via-transparent to-red-700/20"></div>

    <!-- Container -->
    <div class="relative z-10 min-h-screen flex items-center justify-center px-4">
        <!-- Card -->
        <div class="w-full max-w-5xl bg-white rounded-xl shadow-xl overflow-hidden grid grid-cols-1 lg:grid-cols-2">
            <!-- LEFT (Desktop Only) -->

            <div class="hidden lg:flex relative items-center justify-center bg-cover bg-center" <% if (!errors ||
                Object.keys(errors).length===0) { %>
                style="background-image: url('https://greenoasistravel.com/frontend/images/achivements-image.webp');"
                <% } else { %>
                    style="background-color: #f43f5e;"
                    <% } %>
                        >
                        <% if (errors && Object.keys(errors).length> 0) { %>

                            <!-- Error Card ONLY (no overlay, no image) -->
                            <div class="max-w-sm w-full mx-6 rounded-xl bg-white p-6 shadow-xl border border-red-200">
                                <div class="flex gap-3">
                                    <span class="text-red-600 text-xl">⚠️</span>
                                    <div>
                                        <h3 class="text-sm font-semibold text-red-700 mb-2">
                                            Please fix the following errors
                                        </h3>
                                        <ul class="text-sm text-red-600 list-disc list-inside space-y-1">
                                            <% Object.values(errors).forEach(msg=> { %>
                                                <li>
                                                    <%= msg %>
                                                </li>
                                                <% }) %>
                                        </ul>
                                    </div>
                                </div>
                            </div>

                            <% } %>
            </div>


            <!-- RIGHT (Signup Form) -->
            <div class="p-8 sm:p-10">
                <h1 class="text-2xl font-semibold text-gray-900 mb-1">Sign Up</h1>
                <p class="text-sm text-gray-500 mb-6">
                    Welcome! Create your account to start booking and hosting amazing
                    homes.
                </p>



                <form action="/signup" method="POST" class="space-y-4">
                    <!-- Email -->
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Email</label>
                        <input type="email" name="email" placeholder="📧 Jhon23kumar@gmail.com" value="<%= oldInput?.email || '' %>"required
                            class="w-full px-3 py-2 border rounded-md focus:ring-1 focus:ring-red-600" />
                    </div>

                    <!-- Name -->
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">First Name</label>
                            <input type="text" name="firstName" placeholder="👤 Jhon" required value="<%= oldInput?.firstName || '' %>"
                                class="w-full px-3 py-2 border rounded-md focus:ring-1 focus:ring-red-600" />
                        </div>

                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">Last Name</label>
                            <input type="text" name="lastName" placeholder="👤 Don" required value="<%= oldInput?.lastName || ' ' %>"
                                class="w-full px-3 py-2 border rounded-md focus:ring-1 focus:ring-red-600" />
                        </div>
                    </div>

                    <!-- Password -->
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Password</label>
                        <input type="password" name="password" placeholder="🔒 Enter Password" required
                            class="w-full px-3 py-2 border rounded-md focus:ring-1 focus:ring-red-600" />
                    </div>

                    <!-- User Type -->
                    <div>
                        <p class="text-sm font-medium text-gray-700 mb-3">
                            Choose account type
                        </p>
                        <div class="grid grid-cols-2 gap-4">
                            <!-- Guest -->
                            <label class="cursor-pointer">
                                <input type="radio" name="userType" value="guest" class="peer hidden" checked />
                                <div
                                    class="border rounded-xl p-4 peer-checked:border-rose-500 peer-checked:bg-rose-50 transition">
                                    🧳 Guest
                                </div>
                            </label>

                            <!-- Host -->
                            <label class="cursor-pointer">
                                <input type="radio" name="userType" value="host" class="peer hidden" />
                                <div
                                    class="border rounded-xl p-4 peer-checked:border-blue-500 peer-checked:bg-blue-50 transition">
                                    🏠 Host
                                </div>
                            </label>
                        </div>
                    </div>

                    <!-- Terms -->
                    <label class="flex gap-3 text-sm text-gray-600">
                        <input type="checkbox" name="terms" required class="mt-1" />
                        I agree to the
                        <span class="text-rose-500">Terms & Conditions</span>
                    </label>

                    <!-- Submit -->
                    <button type="submit"
                        class="w-full bg-red-600 text-white py-2 rounded-md font-medium hover:bg-red-700">
                        Register
                    </button>

                    <p class="text-sm text-gray-500 text-center">
                        Already have an account?
                        <a href="/login" class="text-red-600 font-medium hover:underline">Log in</a>
                    </p>
                </form>
            </div>
        </div>
    </div>
</body>

</html>