<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Home Added Successfully</title>
  <link href="/output.css" rel="stylesheet" />
</head>

<body class="min-h-screen flex items-center justify-center bg-linear-to-br from-rose-100 via-pink-100 to-purple-100">
  
  <!-- Success Card -->
  <main class="bg-white shadow-2xl rounded-3xl px-10 py-14 text-center max-w-md w-full">

    <!-- Success Icon -->
    <div class="mx-auto mb-6 w-20 h-20 flex items-center justify-center rounded-full bg-rose-100">
      <span class="text-4xl">🏡</span>
    </div>

    <!-- Title -->
    <h1 class="text-3xl font-extrabold text-gray-800">
      Home Added Successfully!
    </h1>

    <!-- Message -->
    <p class="mt-4 text-gray-600 leading-relaxed">
      Your home has been listed on Airbnb. Guests can now discover and book your place.
    </p>

    <!-- Buttons -->
    <div class="mt-10 flex flex-col sm:flex-row gap-4 justify-center">
      <a
        href="/"
        class="bg-rose-500 text-white px-8 py-3 rounded-full font-semibold hover:bg-rose-600 transition shadow-lg"
      >
        Return to Home
      </a>

      <a
        href="/host/add-home"
        class="border border-gray-300 px-8 py-3 rounded-full font-semibold text-gray-700 hover:bg-gray-100 transition"
      >
        Add Another Home
      </a>
    </div>

  </main>

</body>
</html>
