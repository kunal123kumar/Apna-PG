<%- include('../partials/head') %>
    </head>

    <body class="bg-gray-50 text-gray-900">

        <%- include('../partials/header') %>

            <!-- HERO IMAGE -->
            <section class="relative h-[85vh] w-full">
                <img src="<%= home.image_file %>" alt="Home Image"
                    class="absolute inset-0 w-full h-full object-cover" />

                <!-- Overlay -->
                <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/40 to-transparent"></div>

                <!-- Floating Content -->
                <div class="relative z-10 h-full flex flex-col justify-end px-6 md:px-20 pb-12">
                    <div class="max-w-5xl">

                        <span
                            class="inline-flex items-center gap-2 bg-yellow-400 text-black px-4 py-1 rounded-full font-bold mb-4">
                            ⭐ <%= home.rating %> / 5
                        </span>

                        <h1 class="text-4xl md:text-6xl font-extrabold text-white leading-tight">
                            <%= home.name %>
                        </h1>

                        <p class="text-white/90 text-lg mt-2">
                            📍 <%= home.location %>
                        </p>

                        <p class="text-white/70 mt-1 text-sm">
                            Home ID: <%= home._id %>
                        </p>
                    </div>
                </div>
            </section>

            <!-- DETAILS SECTION -->
            <section class="px-6 md:px-20 py-16 bg-white">
                <div class="max-w-6xl mx-auto grid grid-cols-1 md:grid-cols-3 gap-12">

                    <!-- LEFT CONTENT -->
                    <div class="md:col-span-2 space-y-10">

                        <!-- OWNER -->
                        <div>
                            <h2 class="text-xl font-bold mb-3">Hosted by</h2>
                            <div class="flex items-center gap-4">
                                <div
                                    class="w-14 h-14 rounded-full bg-indigo-600 text-white flex items-center justify-center text-xl">
                                    👤
                                </div>
                                <div>
                                    <p class="font-semibold text-lg">
                                        <%= home.houseowner %>
                                    </p>
                                    <p class="text-gray-500 text-sm">Verified Host</p>
                                </div>
                            </div>
                        </div>

                        <!-- DESCRIPTION -->
                        <div>
                            <h2 class="text-xl font-bold mb-3">About this home</h2>
                            <p class="text-gray-700 leading-relaxed">
                                <%= home.description %>
                            </p>
                        </div>

                        <!-- RATING -->
                        <div>
                            <h2 class="text-xl font-bold mb-3">Guest Rating</h2>
                            <div class="flex gap-1">
                                <% for(let i=1; i <=5; i++) { %>
                                    <svg class="w-6 h-6 <%= i <= home.rating ? 'text-yellow-400' : 'text-gray-300' %>"
                                        fill="currentColor" viewBox="0 0 20 20">
                                        <path
                                            d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.719c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                                    </svg>
                                    <% } %>
                            </div>
                        </div>

                    </div>

                    <!-- RIGHT STICKY CTA -->
                    <aside class="md:sticky md:top-28 h-fit space-y-6">
                        <div class="border border-gray-200 rounded-xl p-6">
                            <p class="text-sm text-gray-500">Interested?</p>
                            <button
                                class="mt-4 w-full bg-indigo-600 text-white py-4 rounded-xl font-bold text-lg hover:bg-indigo-700 transition">
                                📞 Contact Owner
                            </button>


                            <form action="/booking/<%= home._id %>" method="post">

                                <button
                                    class="mt-4 w-full bg-green-500 text-white py-4 rounded-xl font-bold text-lg hover:bg-green-700 transition">
                                    🚀 Rental Booking
                                </button>
                            </form>

                            <%- include('../partials/favourities', { home: home, button_name: "DETAILS" ,
                                style: "mt-3 w-full border border-indigo-600 text-indigo-600 py-4 rounded-xl font-bold hover:bg-indigo-50 transition"
                                }) %>


                        </div>
                    </aside>

                </div>
            </section>

    </body>

    </html>