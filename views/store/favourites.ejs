<%- include('../partials/head',{Page_title})%>
</head>
<%- include('../partials/header') %>

<body class="min-h-screen bg-gradient-to-br from-rose-100 via-pink-100 to-purple-200 overflow-x-hidden">

<!-- Decorative blur blobs -->
<div class="absolute top-[-6rem] left-[-6rem] w-72 h-72 bg-pink-300 rounded-full blur-3xl opacity-30"></div>
<div class="absolute bottom-[-6rem] right-[-6rem] w-72 h-72 bg-purple-300 rounded-full blur-3xl opacity-30"></div>

<!-- Hero -->
<main class="relative py-16 text-center">
  <h1 class="text-5xl font-extrabold bg-gradient-to-r from-indigo-600 to-purple-600 bg-clip-text text-transparent">
    Favourite Homes
  </h1>
  <p class="mt-3 text-gray-600">Hand-picked stays you’ll love ❤️</p>

  <div class="flex justify-center mt-6">
    <span class="w-40 h-1 bg-gradient-to-r from-indigo-500 to-purple-500 rounded-full"></span>
  </div>
</main>

<section class="relative px-6 pb-16">
  <div class="max-w-7xl mx-auto grid gap-8
        grid-cols-1 sm:grid-cols-2 lg:grid-cols-3">

    <% FavouritesData.forEach(home=> { %>

    <!-- Card -->
    <div class="group bg-white/70 backdrop-blur-xl rounded-2xl shadow-lg
                hover:shadow-2xl hover:-translate-y-2
                transition-all duration-300 overflow-hidden">

      <!-- Image -->
      <div class="relative overflow-hidden">
        <img src="<%= home.image_file %>"
             alt="<%= home.name %>"
             class="w-full h-56 object-cover
                    group-hover:scale-110 transition-transform duration-500" />

        <!-- Gradient overlay -->
        <div class="absolute inset-0 bg-gradient-to-t from-black/40 to-transparent"></div>

        <!-- Price badge -->
        <span class="absolute top-4 right-4 bg-white/90 text-gray-900
                     px-4 py-1 rounded-full text-sm font-semibold shadow">
          ₹<%= home.price %>
        </span>
      </div>

      <!-- Content -->
      <div class="p-6">
        <div class="flex justify-between items-center mb-2">
          <h2 class="text-xl font-bold text-gray-800">
            <%= home.name %>
          </h2>

          <span class="flex items-center gap-1 text-sm
                       bg-yellow-100 text-yellow-700
                       px-3 py-1 rounded-full">
            ⭐ <%= home.rating %>
          </span>
        </div>

        <p class="text-gray-600 text-sm mb-4 line-clamp-2">
          <%= home.description %>
        </p>

        <div class="text-sm text-gray-700 space-y-1">
          <p>📍 <span class="font-medium"><%= home.location %></span></p>
          <p>👤 Owner: <span class="font-medium"><%= home.houseowner %></span></p>
        </div>

        <!-- Buttons -->
        <div class="flex flex-col sm:flex-row gap-4 mt-6">

          <%- include('../partials/favourities', { 
            home: home,
            button_name: "Remove from favourites",
            style: `
              w-full sm:w-auto px-6 py-3 text-sm font-semibold
              rounded-xl text-indigo-600 border border-indigo-600
              hover:bg-indigo-600 hover:text-white
              transition-all duration-300 shadow-sm
            `
          }) %>

          <a href="/home/<%= home._id %>" class="w-full sm:w-auto">
            <button class="w-full px-6 py-3 text-sm font-semibold
                           rounded-xl text-green-600 border border-green-600
                           hover:bg-green-600 hover:text-white
                           transition-all duration-300 shadow-sm">
              Details 👀
            </button>
          </a>

        </div>
      </div>
    </div>

    <% }) %>

  </div>
</section>

</body>
</html>
